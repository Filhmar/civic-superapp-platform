# Runtime
NODE_ENV=development

# API Gateway
API_GATEWAY_PORT=3005
CORS_ORIGINS=http://localhost:8081,http://localhost:19006,http://localhost:5173,http://localhost:5174,http://localhost:8090,http://localhost:8091

# Service TCP ports/hosts (override hosts to compose service names in Docker)
TENANCY_SERVICE_TCP_HOST=localhost
TENANCY_SERVICE_TCP_PORT=3006
IDENTITY_SERVICE_TCP_HOST=localhost
IDENTITY_SERVICE_TCP_PORT=3007
EGOV_SERVICE_TCP_HOST=localhost
EGOV_SERVICE_TCP_PORT=3008
REPORTS_SERVICE_TCP_HOST=localhost
REPORTS_SERVICE_TCP_PORT=3009
ASSISTANCE_SERVICE_TCP_HOST=localhost
ASSISTANCE_SERVICE_TCP_PORT=3010
EMERGENCY_SERVICE_TCP_HOST=localhost
EMERGENCY_SERVICE_TCP_PORT=3011
CONTENT_SERVICE_TCP_HOST=localhost
CONTENT_SERVICE_TCP_PORT=3012
PLACES_SERVICE_TCP_HOST=localhost
PLACES_SERVICE_TCP_PORT=3013
NOTIFICATION_SERVICE_TCP_HOST=localhost
NOTIFICATION_SERVICE_TCP_PORT=3014
MEDIA_SERVICE_TCP_HOST=localhost
MEDIA_SERVICE_TCP_PORT=3016
INTEGRATION_SERVICE_TCP_HOST=localhost
INTEGRATION_SERVICE_TCP_PORT=3017

# Metrics (per-service; distinct on a shared host)
METRICS_PORT=9464

# Postgres (per-service database URLs)
TENANCY_SERVICE_DATABASE_URL=postgresql://civic:civic_dev_password@localhost:5432/tenancy
IDENTITY_SERVICE_DATABASE_URL=postgresql://civic:civic_dev_password@localhost:5432/identity
EGOV_SERVICE_DATABASE_URL=postgresql://civic:civic_dev_password@localhost:5432/egov

# MongoDB (per-service databases on one instance)
MONGODB_REPORTS_URI=mongodb://localhost:27017/reports
MONGODB_ASSISTANCE_URI=mongodb://localhost:27017/assistance
MONGODB_EMERGENCY_URI=mongodb://localhost:27017/emergency
MONGODB_CONTENT_URI=mongodb://localhost:27017/content
MONGODB_PLACES_URI=mongodb://localhost:27017/places
MONGODB_NOTIFICATION_URI=mongodb://localhost:27017/notification
MONGODB_MEDIA_URI=mongodb://localhost:27017/media

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT (secrets must be >= 64 chars)
JWT_ACCESS_SECRET=change_me________________________________________________________64chars
JWT_REFRESH_SECRET=change_me________________________________________________________64chars
JWT_ACCESS_EXPIRES_IN=900
JWT_REFRESH_EXPIRES_IN=604800
# Digital Resident ID signed-QR (JWS) secret
DIGITAL_ID_QR_SECRET=change_me________________________________________________________64chars

# OTP
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=5
MAX_OTP_ATTEMPTS=5
MAX_OTP_REQUESTS_PER_PHONE_PER_HOUR=5
MAX_OTP_REQUESTS_PER_PHONE_PER_DAY=15
MAX_OTP_REQUESTS_PER_IP_PER_HOUR=20
# Dev/demo OTP dispatch: 'mock' logs the code instead of sending SMS
SMS_PROVIDER=mock

# Object storage (S3-compatible; path-style required for MinIO)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=civic_minio
S3_SECRET_KEY=civic_minio_password
S3_BUCKET=civic-media
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# Integrations
WEATHER_PROVIDER=mock

# App/product
APP_MIN_SUPPORTED_VERSION=1.0.0

# Socket.io
SOCKET_IO_ADAPTER=memory

# Admin plane (separate secrets per STACK.md admin-plane isolation)
ADMIN_SERVICE_TCP_HOST=localhost
ADMIN_SERVICE_TCP_PORT=3018
ADMIN_SERVICE_DATABASE_URL=postgresql://civic:civic_dev_password@localhost:5432/admin
JWT_ADMIN_ACCESS_SECRET=change_me________________________________________________________64chars
JWT_ADMIN_REFRESH_SECRET=change_me________________________________________________________64chars
ADMIN_SEED_EMAIL=admin@platform.local
ADMIN_SEED_PASSWORD=PlatformAdmin!2026
