{
  "name": "civic-platform-backend",
  "version": "0.1.0",
  "description": "Civic Super-App Platform — multi-tenant microservices backend",
  "private": true,
  "license": "UNLICENSED",
  "type": "commonjs",
  "scripts": {
    "build": "nest build api-gateway && nest build tenancy-service",
    "build:all": "for a in api-gateway tenancy-service identity-service content-service notification-service integration-service reports-service media-service egov-service assistance-service emergency-service places-service admin-service geo-service; do nest build $a || exit 1; done",
    "start:dev": "nest start --watch",
    "lint": "eslint \"{apps,libs}/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:cov": "jest --coverage",
    "prisma:generate": "prisma generate --config apps/tenancy-service/prisma.config.ts && prisma generate --config apps/identity-service/prisma.config.ts && prisma generate --config apps/egov-service/prisma.config.ts && prisma generate --config apps/admin-service/prisma.config.ts",
    "prisma:migrate": "prisma migrate dev --config apps/tenancy-service/prisma.config.ts && prisma migrate dev --config apps/identity-service/prisma.config.ts && prisma migrate dev --config apps/admin-service/prisma.config.ts && prisma migrate dev --config apps/egov-service/prisma.config.ts",
    "seed:all": "npm run seed:tenants && ts-node -P tsconfig.scripts.json scripts/seed-content.ts && ts-node -P tsconfig.scripts.json scripts/seed-report-categories.ts && ts-node -P tsconfig.scripts.json scripts/seed-egov-catalog.ts && ts-node -P tsconfig.scripts.json scripts/seed-emergency-assistance.ts && ts-node -P tsconfig.scripts.json scripts/seed-places.ts && ts-node -P tsconfig.scripts.json scripts/seed-geo.ts",
    "seed:tenants": "ts-node -P tsconfig.scripts.json apps/tenancy-service/prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1070.0",
    "@aws-sdk/s3-request-presigner": "^3.1070.0",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/microservices": "^11.1.6",
    "@nestjs/mongoose": "^11.0.3",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.1.18",
    "@nestjs/schedule": "^6.0.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/throttler": "^6.4.0",
    "@nestjs/websockets": "^11.1.18",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@turf/turf": "^7.3.5",
    "axios": "^1.13.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "dompurify": "^3.4.2",
    "dotenv": "^16.4.0",
    "expo-server-sdk": "^6.1.0",
    "geojson-vt": "^4.0.3",
    "helmet": "^8.1.0",
    "ioredis": "^5.7.0",
    "jsdom": "^26.1.0",
    "mongoose": "^8.16.4",
    "nest-winston": "^1.10.2",
    "nestjs-cls": "^6.1.0",
    "pg": "^8.19.0",
    "pmtiles": "^4.4.1",
    "prisma": "^7.0.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "ua-parser-js": "^2.0.10",
    "vt-pbf": "^3.1.3",
    "winston": "^3.18.3",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^5.0.2",
    "@types/dompurify": "^3.0.5",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "jest": "^30.2.0",
    "prettier": "^3.4.2",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.0.0",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "overrides": {
    "minimatch": "^10.2.1",
    "glob": "^11.0.0",
    "schema-utils": "^4.3.0",
    "node-forge": "^1.4.0",
    "ws": "^8.21.0",
    "form-data": "^4.0.6",
    "js-yaml": "^4.1.2",
    "multer": "^2.1.2",
    "undici": "^7.27.3",
    "uuid": "^11.1.1"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.spec.json"
        }
      ]
    },
    "collectCoverageFrom": [
      "apps/**/*.(t|j)s",
      "libs/**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/",
      "<rootDir>/libs/"
    ],
    "moduleNameMapper": {
      "^@app/common(|/.*)$": "<rootDir>/libs/common/src/$1",
      "^@app/redis(|/.*)$": "<rootDir>/libs/redis/src/$1",
      "^@app/mongodb(|/.*)$": "<rootDir>/libs/mongodb/src/$1"
    }
  }
}
