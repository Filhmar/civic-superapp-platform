# Mobile application environment (Expo SDK 54)
# Copy to `.env` and adjust. All vars are OPTIONAL — each has a code default.
#
# Two kinds of vars:
#   EXPO_PUBLIC_*  -> read at RUNTIME, inlined into the JS bundle (NOT secret).
#                     The only place these are read is constants/env.ts.
#   APP_VARIANT    -> read at BUILD time by app.config.ts (white-label identity).

# ---- Runtime (constants/env.ts) --------------------------------------------

# Backend API Gateway base URL. Default: http://localhost:3005
# Use your machine LAN IP (not localhost) when testing on a physical device,
# e.g. http://192.168.1.20:3005
EXPO_PUBLIC_API_URL=http://localhost:3005

# Tenant bundle id -> sent as X-Tenant-ID. Dev/Expo Go/web fallback only;
# installed white-label builds derive this from the native applicationId.
# Empty = unresolved (app shows first-launch retry screen).
# One of: com.dasmarinas.app | com.sorsogon.app | com.legazpi.app
EXPO_PUBLIC_TENANT_BUNDLE_ID=com.dasmarinas.app

# ---- Build-time (app.config.ts) --------------------------------------------

# Selects white-label variant from tenant-variants.json.
# One of: dasmarinas | sorsogon | legazpi
# Unset = first variant in the file (dasmarinas).
APP_VARIANT=dasmarinas
